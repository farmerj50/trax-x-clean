# Backend-only secrets and feature flags.
# Do not prefix secrets with REACT_APP_.

POLYGON_API_KEY=your_polygon_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

ENABLE_MARKET_SIGNALS=true
ENABLE_OPTIONS_FLOW_SIGNALS=false
ENABLE_LSTM_STARTUP_TRAINING=false
MARKET_SIGNALS_BIG_PRINT_THRESHOLD=10000000
MARKET_SIGNALS_SUBSCRIBE=
INTRINIO_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

AUTH_ENABLED=true
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_MIN_PASSWORD_LENGTH=12
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:5000,http://127.0.0.1:5000,https://trax-x-clean-production.up.railway.app,https://keen-hope-production-4a15.up.railway.app

ENABLE_TRADING=true
TRADING_PROVIDER=paper
TRADING_MODE=paper
TRADING_STARTING_CASH=100000
TRADING_PAPER_AUTO_FILL=true
TRADING_MAX_ORDER_NOTIONAL=100
TRADING_MAX_ORDER_QTY=100
TRADING_ALLOWED_SYMBOLS=
TRADING_ALLOW_SHORT_SELLS=false
TRADING_REQUIRE_MARKET_OPEN=false

ALPACA_BROKER_ENV=sandbox
ALPACA_BROKER_API_BASE=https://broker-api.sandbox.alpaca.markets
ALPACA_BROKER_AUTH_MODE=client_credentials
ALPACA_BROKER_AUTH_BASE=https://authx.sandbox.alpaca.markets
ALPACA_BROKER_API_KEY=your_broker_client_id
ALPACA_BROKER_API_SECRET=your_broker_client_secret
ALPACA_BROKER_ENABLED=false
ALPACA_BROKER_ACCOUNT_ID=
ALPACA_BROKER_FIRM_ACCOUNT_NUMBER=
ALPACA_BROKER_TIMEOUT_SECONDS=15
ALPACA_BROKER_ALLOW_ORDERS=false
